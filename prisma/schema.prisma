generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "debian-openssl-3.0.x"]
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "general_merchandise"]
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String   @default("ok")
  createdAt DateTime @default(now())
  @@schema("public")
}

model Customer {
  id                     Int                      @id @default(autoincrement())
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  date                   String                   @db.VarChar(50)
  customerName           String                   @db.VarChar(255)
  phoneNumber            String                   @db.VarChar(100)
  address                String                   @db.VarChar(500)
  facebook               String                   @db.VarChar(255)
  emailAddress           String                   @db.VarChar(255)
  businessName           String                   @db.VarChar(255)
  taxNumber              String                   @db.VarChar(100)
  businessAddress        String                   @db.VarChar(500)
  businessContactNumber  String                   @db.VarChar(100)
  customerStatus         String                   @db.VarChar(50)
  deletedAt              DateTime?
  additionalCustomerInfo AdditionalCustomerInfo[]
  truckingInvoices       TruckingInvoice[]
  truckingPayments       TruckingPayment[]
  truckingTrips          TruckingTrip[]

  @@index([customerName])
  @@index([phoneNumber])
  @@index([customerStatus])
  @@schema("public")
}

model AdditionalCustomerInfo {
  id         Int       @id @default(autoincrement())
  customerId Int
  type       String    @db.VarChar(50)
  value      String    @db.VarChar(500)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@map("additional_customer_info")
  @@schema("public")
}

model Price {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  productCode     String    @db.VarChar(100)
  lowerLimit      Int
  upperLimit      Int
  currentPrice    Int
  priceAdjustment Int       @default(0)
  description     String?   @db.VarChar(500)
  category        String?   @db.VarChar(100)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  @@index([productCode])
  @@index([productCode, lowerLimit, upperLimit])
  @@index([isActive])
  @@map("prices")
  @@schema("public")
}

model Product {
  id                     Int          @id @default(autoincrement())
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  shipmentCode           String?      @db.VarChar(100)
  cvNumber               String?      @db.VarChar(100)
  noOfSacks              Float        @default(0)
  totalCBM               Float        @default(0)
  weight                 Float        @default(0)
  shipmentStatus         String?      @db.VarChar(100)
  postingDate            String?      @db.VarChar(50)
  orderDate              String?      @db.VarChar(50)
  payment                String?      @db.VarChar(100)
  product                String?      @db.VarChar(500)
  productCode            String?      @db.VarChar(100)
  ageRange               String?      @db.VarChar(100)
  unit                   String?      @db.VarChar(50)
  unitPrice              Float        @default(0)
  quantity               Float        @default(0)
  alibabaShippingCost    Float        @default(0)
  exchangeRates          Float        @default(0)
  php                    Float        @default(0)
  subTotalPHP            Float        @default(0)
  transactionFee         Float        @default(0)
  grandTotal             Float        @default(0)
  forwardersFee          Float        @default(0)
  lalamove               Float        @default(0)
  packagingCost          Float        @default(0)
  suggestedPrice         Float        @default(0)
  actualPrice            Float        @default(0)
  landedUnitCost         Float        @default(0)
  cogs                   Float        @default(0)
  projectedSales         Float        @default(0)
  projectedProfit        Float        @default(0)
  projectedProfitPercent Float        @default(0)
  totalMarkup            Float        @default(0)
  deletedAt              DateTime?
  linkToPost             String?      @db.VarChar(1000)
  bulkQuantity           Float        @default(0)
  bulkWeight             Float        @default(0)
  weightPerPiece         Float        @default(0)
  paymentCardId          String?      @db.VarChar(100)
  paymentMethod          String?      @db.VarChar(50)
  paymentCard            PaymentCard? @relation(fields: [paymentCardId], references: [id])

  @@index([productCode])
  @@index([shipmentCode])
  @@index([shipmentStatus])
  @@index([payment])
  @@index([paymentMethod])
  @@index([paymentCardId])
  @@index([ageRange])
  @@map("products")
  @@schema("public")
}

model BundleBatch {
  id          Int                    @id @default(autoincrement())
  createdAt   DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  postingDate String                 @db.VarChar(50)
  bundleName  String                 @db.VarChar(255)
  bundleSku   String                 @unique @db.VarChar(255)
  quantity    Float                  @default(0)
  price       Float                  @default(0)
  components  BundleBatchComponent[]

  @@index([bundleSku])
  @@index([postingDate])
  @@map("bundle_batches")
  @@schema("public")
}

model BundleBatchComponent {
  id                   Int         @id @default(autoincrement())
  createdAt            DateTime    @default(now()) @db.Timestamptz(6)
  bundleBatchId        Int
  componentProductCode String      @db.VarChar(100)
  includedQuantity     Float       @default(0)
  bundleBatch          BundleBatch @relation(fields: [bundleBatchId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bundleBatchId])
  @@index([componentProductCode])
  @@map("bundle_batch_components")
  @@schema("public")
}

model InventoryMovement {
  id          Int             @id @default(autoincrement())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
  postingDate String?         @db.VarChar(50)
  productCode String          @db.VarChar(100)
  quantity    Float
  fromBucket  InventoryBucket
  toBucket    InventoryBucket
  notes       String?
  deletedAt   DateTime?

  @@index([productCode])
  @@index([fromBucket])
  @@index([toBucket])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("inventory_movements")
  @@schema("public")
}

model PaymentCard {
  id         String    @id @default(cuid())
  bank       String    @db.VarChar(100)
  label      String    @db.VarChar(100)
  nameOnCard String    @db.VarChar(255)
  last4      String?   @db.VarChar(4)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  expenses   Expense[]
  products   Product[]

  @@index([bank])
  @@index([label])
  @@map("payment_cards")
  @@schema("public")
}

model ShippingFeeCalculatorState {
  id                    Int       @id @default(autoincrement())
  shipmentCode          String    @unique @db.VarChar(100)
  actualAlibabaShipping Float     @default(0)
  actualForwardersFee   Float     @default(0)
  actualLalamove        Float     @default(0)
  multipliers           Json
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  @@map("shipping_fee_calculator_states")
  @@schema("public")
}

model Shipment {
  id             Int       @id @default(autoincrement())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  shipmentCode   String    @db.VarChar(100)
  cvNumber       String?   @db.VarChar(100)
  noOfSacks      Int       @default(0)
  totalCBM       Float     @default(0)
  weight         Float     @default(0)
  fee            Float     @default(0)
  shipmentStatus String    @db.VarChar(100)
  dateCreated    String?   @db.VarChar(50)
  dateDelivered  String?   @db.VarChar(50)
  duration       String?   @db.VarChar(20)
  notes          String?
  deletedAt      DateTime?

  @@index([shipmentCode])
  @@index([shipmentStatus])
  @@map("shipments")
  @@schema("public")
}

model TruckingFleetRegistry {
  id                String    @id @default(cuid())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  truckId           String    @unique @db.VarChar(50)
  maker             String    @db.VarChar(100)
  model             String    @db.VarChar(100)
  year              Int
  plateNo           String    @db.VarChar(50)
  bodyNo            String?   @db.VarChar(100)
  chassisNo         String?   @db.VarChar(100)
  orCrInfo          String?   @db.VarChar(100)
  ltoRegisterDate   String    @db.VarChar(50)
  engineNo          String?   @db.VarChar(100)
  capacity          String?   @db.VarChar(50)
  passengerCapacity String?   @db.VarChar(50)
  grossWeight       String?   @db.VarChar(50)
  netWeight         String?   @db.VarChar(50)
  bodyType          String?   @db.VarChar(100)
  series            String?   @db.VarChar(100)
  classification    String?   @db.VarChar(100)
  vehicleType       String    @db.VarChar(100)
  fuelType          String    @db.VarChar(50)
  status            String    @default("active") @db.VarChar(20)
  remarks           String?
  ownershipType     String?   @db.VarChar(50)
  acquisitionDate   String?   @db.VarChar(50)
  purchaseCost      String?   @db.VarChar(100)
  insuranceProvider String?   @db.VarChar(100)
  insuranceExpiry   String?   @db.VarChar(50)
  gpsTrackerId      String?   @db.VarChar(100)
  depotLocation     String?   @db.VarChar(100)
  driverAssigned    String?   @db.VarChar(100)
  deletedAt         DateTime?

  @@index([status])
  @@index([maker])
  @@index([vehicleType])
  @@index([fuelType])
  @@map("trucking_fleet_registry")
  @@schema("public")
}

model TruckingTrip {
  id            String           @id @default(cuid())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  date          String           @db.VarChar(50)
  truckId       String           @db.VarChar(50)
  driver        String           @db.VarChar(255)
  helper        String?          @db.VarChar(255)
  grossRevenue  Float
  fuelCost      Float
  maintenance   Float
  tollFees      Float
  miscExpenses  Float
  totalExpenses Float
  remarks       String?          @db.VarChar(1000)
  deletedAt     DateTime?
  destination   String           @default("") @db.VarChar(255)
  fuelLiters    Float            @default(0)
  completedAt   DateTime?
  customerId    Int?
  invoiceId     String?
  status        String           @default("draft") @db.VarChar(30)
  customer      Customer?        @relation(fields: [customerId], references: [id])
  invoice       TruckingInvoice? @relation(fields: [invoiceId], references: [id])

  @@index([date])
  @@index([truckId])
  @@index([driver])
  @@index([helper])
  @@index([customerId])
  @@index([invoiceId])
  @@index([status])
  @@index([customerId, date])
  @@map("trucking_trips")
  @@schema("public")
}

model TruckingVehicleAssignment {
  id        String                          @id @default(cuid())
  createdAt DateTime                        @default(now())
  updatedAt DateTime                        @updatedAt
  vehicleId String                          @db.VarChar(50)
  plateNo   String                          @db.VarChar(50)
  driver    String                          @db.VarChar(255)
  helper    String                          @db.VarChar(255)
  startDate String                          @db.VarChar(50)
  endDate   String                          @db.VarChar(50)
  status    TruckingVehicleAssignmentStatus @default(scheduled)
  route     String?                         @db.VarChar(255)
  notes     String?
  deletedAt DateTime?

  @@index([vehicleId])
  @@index([status])
  @@index([createdAt])
  @@map("trucking_vehicle_assignments")
  @@schema("public")
}

model Transaction {
  id            Int                       @id @default(autoincrement())
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  orderDate     String?                   @db.VarChar(50)
  customers     String?                   @db.VarChar(255)
  productCode   String?                   @db.VarChar(100)
  quantity      Float?
  unitPrice     Float?
  discount      Float?
  adjustment    Float?
  lineTotal     Float?
  refundQty     Float?
  refundAmount  Float?
  refundDate    String?                   @db.VarChar(50)
  orderStatus   String?                   @db.VarChar(100)
  notes         String?
  invoiceDate   String?                   @db.VarChar(50)
  packedDate    String?                   @db.VarChar(50)
  shipmentCode  String?                   @db.VarChar(100)
  deletedAt     DateTime?
  statusChanges TransactionStatusChange[]
  refunds       TransactionRefund[]
  payments      TransactionPayment[]

  @@index([orderDate])
  @@index([customers])
  @@index([productCode])
  @@index([orderStatus])
  @@index([shipmentCode])
  @@index([customers, deletedAt])
  @@index([orderStatus, deletedAt])
  @@index([productCode, deletedAt])
  @@index([orderDate, deletedAt])
  @@map("transactions")
  @@schema("public")
}

model TransactionPayment {
  id            Int         @id @default(autoincrement())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  transactionId Int
  paymentDate   String      @db.VarChar(50)
  amount        Float       @default(0)
  method        String?     @db.VarChar(100)
  notes         String?
  isReservation Boolean     @default(false)
  deletedAt     DateTime?
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([paymentDate])
  @@index([deletedAt])
  @@map("transaction_payments")
  @@schema("public")
}

model TransactionRefund {
  id              Int             @id @default(autoincrement())
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  transactionId    Int
  refundDate       String          @db.VarChar(50)
  amount           Float           @default(0)
  reason           String?         @db.VarChar(255)
  returnedQuantity Float?
  restockBucket    InventoryBucket?
  notes            String?
  deletedAt        DateTime?
  transaction      Transaction     @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId])
  @@index([refundDate])
  @@index([deletedAt])
  @@map("transaction_refunds")
  @@schema("public")
}

model TransactionStatusChange {
  id             Int         @id @default(autoincrement())
  transactionId  Int
  previousStatus String?     @db.VarChar(100)
  newStatus      String?     @db.VarChar(100)
  changedAt      DateTime    @default(now())
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId, changedAt])
  @@map("transaction_status_changes")
  @@schema("public")
}

model OperationsNotification {
  id        String   @id @default(cuid())
  category  String   @db.VarChar(50)
  user      String?  @db.VarChar(100)
  changes   String   @db.VarChar(1000)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([category, createdAt])
  @@map("operations_notifications")
  @@schema("public")
}

model SortingDistribution {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  productCode      String    @db.VarChar(100)
  selectedQuantity Int?
  rowNumber        Int
  quantity         Float     @default(0)
  percentage       Float     @default(0)
  groupNumber      String    @default("") @db.VarChar(50)
  distribution     Float     @default(0)
  checked          Boolean   @default(false)
  deletedAt        DateTime?

  @@unique([productCode, rowNumber])
  @@index([productCode])
  @@index([groupNumber])
  @@map("sorting_distributions")
  @@schema("public")
}

model InstalledModule {
  id          String   @id @default(cuid())
  moduleId    String   @unique
  name        String   @db.VarChar(255)
  version     String   @db.VarChar(50)
  enabled     Boolean  @default(true)
  source      String   @db.VarChar(50)
  installPath String?  @db.VarChar(500)
  config      Json
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  installedBy String?  @db.VarChar(100)

  @@index([moduleId])
  @@index([enabled])
  @@index([source])
  @@map("installed_modules")
  @@schema("public")
}

model ModuleMarketplace {
  id          String    @id @default(cuid())
  moduleId    String    @unique
  name        String    @db.VarChar(255)
  description String?
  version     String    @db.VarChar(50)
  author      String    @db.VarChar(255)
  authorEmail String?   @db.VarChar(255)
  downloadUrl String    @db.VarChar(1000)
  repository  String?   @db.VarChar(500)
  license     String?   @db.VarChar(100)
  size        Int?
  downloads   Int       @default(0)
  rating      Float?
  screenshots String[]
  keywords    String[]
  config      Json
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([moduleId])
  @@index([published])
  @@index([author])
  @@index([downloads])
  @@map("module_marketplace")
  @@schema("public")
}

model AuditLog {
  id        String   @id @default(cuid())
  model     String   @db.VarChar(100)
  action    String   @db.VarChar(50)
  targetId  String?  @db.VarChar(100)
  before    Json?
  after     Json?
  timestamp DateTime @default(now())

  @@index([model])
  @@index([timestamp])
  @@map("audit_logs")
  @@schema("public")
}

model ChangeLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  userId     String?  @db.VarChar(100)
  userName   String?  @db.VarChar(255)
  entityType String   @db.VarChar(100)
  entityId   String?  @db.VarChar(100)
  action     String   @db.VarChar(50)
  field      String?  @db.VarChar(255)
  oldValue   Json?
  newValue   Json?
  source     String?  @db.VarChar(50)
  metadata   Json?

  @@index([createdAt])
  @@index([entityType])
  @@index([userId])
  @@map("change_log")
  @@schema("public")
}

model Expense {
  id              Int          @id @default(autoincrement())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  date            String       @db.VarChar(50)
  amount          Float
  description     String       @db.VarChar(500)
  category        String       @db.VarChar(100)
  notes           String?
  receipt         String?      @db.VarChar(500)
  status          String       @db.VarChar(20)
  employeeName    String?      @db.VarChar(255)
  sourceType      String       @default("MANUAL") @db.VarChar(50)
  sourceId        String?      @db.VarChar(100)
  sourceLineKey   String?      @db.VarChar(100)
  systemGenerated Boolean      @default(false)
  paymentCardId   String?      @db.VarChar(100)
  paymentMethod   String?      @db.VarChar(50)
  paymentCard     PaymentCard? @relation(fields: [paymentCardId], references: [id])

  @@unique([sourceType, sourceId, sourceLineKey])
  @@index([date])
  @@index([category])
  @@index([status])
  @@index([employeeName])
  @@index([paymentMethod])
  @@index([paymentCardId])
  @@index([sourceType])
  @@index([sourceId])
  @@index([status, date])
  @@index([employeeName, status])
  @@index([category, status])
  @@map("expenses")
  @@schema("public")
}

model ClothingAccountingOpeningBalance {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  date        DateTime @db.Timestamptz(6)
  ref         String   @db.VarChar(120)
  account     String   @db.VarChar(255)
  debit       Float    @default(0)
  credit      Float    @default(0)
  description String?  @db.VarChar(1000)

  @@index([date])
  @@index([account])
  @@index([ref])
  @@map("ClothingAccountingOpeningBalance")
  @@schema("public")
}

model ClothingInventoryReclassEntry {
  id             String   @id @default(cuid())
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  postingDate     DateTime @db.Timestamptz(6)
  shipmentId      Int?
  shipmentCode    String   @db.VarChar(100)
  productCode     String   @db.VarChar(100)
  amount          Float    @default(0)
  fromAccount     String   @db.VarChar(255)
  toAccount       String   @db.VarChar(255)
  triggerStatus   String   @db.VarChar(100)
  idempotencyKey  String   @unique @db.VarChar(220)
  notes           String?  @db.VarChar(1000)
  deletedAt       DateTime? @db.Timestamptz(6)

  @@index([postingDate])
  @@index([shipmentCode])
  @@index([productCode])
  @@index([shipmentId])
  @@index([deletedAt])
  @@map("clothing_inventory_reclass_entries")
  @@schema("public")
}

model ClothingInventoryTransitBuildEntry {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  postingDate    DateTime @db.Timestamptz(6)
  shipmentId     Int?
  shipmentCode   String   @db.VarChar(100)
  amount         Float    @default(0)
  debitAccount   String   @db.VarChar(255)
  creditAccount  String   @db.VarChar(255)
  idempotencyKey String   @unique @db.VarChar(220)
  notes          String?  @db.VarChar(1000)
  deletedAt      DateTime? @db.Timestamptz(6)

  @@index([postingDate])
  @@index([shipmentCode])
  @@index([shipmentId])
  @@index([creditAccount])
  @@index([deletedAt])
  @@map("clothing_inventory_transit_build_entries")
  @@schema("public")
}

model ClothingAccountingJournalLine {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  date            DateTime @db.Timestamptz(6)
  ref             String   @db.VarChar(120)
  account         String   @db.VarChar(255)
  debit           Float    @default(0)
  credit          Float    @default(0)
  description     String?  @db.VarChar(1000)
  sourceType      String   @db.VarChar(50)
  sourceId        String?  @db.VarChar(100)
  sourceLineKey   String   @db.VarChar(150)
  systemGenerated Boolean  @default(true)

  @@unique([sourceType, sourceId, sourceLineKey])
  @@index([date])
  @@index([account])
  @@index([ref])
  @@index([sourceType])
  @@index([sourceId])
  @@map("clothing_accounting_journal_lines")
  @@schema("public")
}

model ClothingRecurringPaymentTemplate {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  name           String   @db.VarChar(255)
  kind           String   @db.VarChar(30) // LOAN | EXPENSE
  amount         Float    @default(0)
  frequency      String   @default("MONTHLY") @db.VarChar(30)
  dayOfMonth     Int
  nextDueDate    DateTime @db.Timestamptz(6)
  endDate        DateTime? @db.Timestamptz(6)
  debitAccount   String   @db.VarChar(255)
  debitTag       String?  @db.VarChar(255)
  creditAccount  String   @db.VarChar(255)
  creditTag      String?  @db.VarChar(255)
  notes          String?  @db.VarChar(1000)
  isActive       Boolean  @default(true)

  drafts ClothingRecurringPaymentDraft[]

  @@index([isActive])
  @@index([nextDueDate])
  @@index([kind])
  @@map("clothing_recurring_payment_templates")
  @@schema("public")
}

model ClothingRecurringPaymentDraft {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  templateId        String
  dueDate           DateTime @db.Timestamptz(6)
  amount            Float    @default(0)
  debitAccount      String   @db.VarChar(255)
  debitTag          String?  @db.VarChar(255)
  creditAccount     String   @db.VarChar(255)
