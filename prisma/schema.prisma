  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  date        DateTime @db.Timestamptz(6)
  ref         String   @db.VarChar(120)
  account     String   @db.VarChar(255)
  debit       Float    @default(0)
  credit      Float    @default(0)
  description String?  @db.VarChar(1000)

  @@index([date])
  @@index([account])
  @@index([ref])
  @@map("accounting_opening_balance")
  @@schema("general_merchandise")
}

model GeneralMerchandiseAccountingJournalLine {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  date            DateTime @db.Timestamptz(6)
  ref             String   @db.VarChar(120)
  account         String   @db.VarChar(255)
  debit           Float    @default(0)
  credit          Float    @default(0)
  description     String?  @db.VarChar(1000)
  sourceType      String   @db.VarChar(50)
  sourceId        String?  @db.VarChar(100)
  sourceLineKey   String   @db.VarChar(150)
  systemGenerated Boolean  @default(true)

  @@unique([sourceType, sourceId, sourceLineKey])
