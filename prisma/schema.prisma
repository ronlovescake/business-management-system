generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String   @default("ok")
  createdAt DateTime @default(now())
}

model Customer {
  id                    Int      @id @default(autoincrement())
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  date                  String   @db.VarChar(50)
  customerName          String   @db.VarChar(255)
  phoneNumber           String   @db.VarChar(100)
  address               String   @db.VarChar(500)
  facebook              String   @db.VarChar(255)
  emailAddress          String   @db.VarChar(255)
  businessName          String   @db.VarChar(255)
  taxNumber             String   @db.VarChar(100)
  businessAddress       String   @db.VarChar(500)
  businessContactNumber String   @db.VarChar(100)
  customerStatus        String   @db.VarChar(50)
}

model Price {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt
  productCode     String   @db.VarChar(100)
  lowerLimit      Int
  upperLimit      Int
  currentPrice    Int
  priceAdjustment Int      @default(0)
  description     String?  @db.VarChar(500)
  category        String?  @db.VarChar(100)
  isActive        Boolean  @default(true)

  @@map("prices")
}

model Product {
  id                     Int      @id @default(autoincrement())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  shipmentCode           String?  @db.VarChar(100)
  cvNumber               String?  @db.VarChar(100)
  noOfSacks              Float    @default(0)
  totalCBM               Float    @default(0)
  weight                 Float    @default(0)
  shipmentStatus         String?  @db.VarChar(100)
  postingDate            String?  @db.VarChar(50)
  orderDate              String?  @db.VarChar(50)
  payment                String?  @db.VarChar(100)
  product                String?  @db.VarChar(500)
  productCode            String?  @db.VarChar(100)
  ageRange               String?  @db.VarChar(100)
  unit                   String?  @db.VarChar(50)
  unitPrice              Float    @default(0)
  quantity               Float    @default(0)
  shippingFee1           Float    @default(0)
  exchangeRates          Float    @default(0)
  php                    Float    @default(0)
  subTotalPHP            Float    @default(0)
  transactionFee         Float    @default(0)
  grandTotal             Float    @default(0)
  shippingFee2           Float    @default(0)
  shippingFee3           Float    @default(0)
  packaging              Float    @default(0)
  suggestedPrice         Float    @default(0)
  actualPrice            Float    @default(0)
  basePrice              Float    @default(0)
  cogs                   Float    @default(0)
  projectedSales         Float    @default(0)
  projectedProfit        Float    @default(0)
  projectedProfitPercent Float    @default(0)
  totalMarkup            Float    @default(0)

  @@map("products")
}
