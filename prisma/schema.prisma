generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String   @default("ok")
  createdAt DateTime @default(now())
}

model Customer {
  id                       Int                            @id @default(autoincrement())
  createdAt                DateTime                       @default(now())
  updatedAt                DateTime                       @updatedAt
  date                     String                         @db.VarChar(50)
  customerName             String                         @db.VarChar(255)
  phoneNumber              String                         @db.VarChar(100)
  address                  String                         @db.VarChar(500)
  facebook                 String                         @db.VarChar(255)
  emailAddress             String                         @db.VarChar(255)
  businessName             String                         @db.VarChar(255)
  taxNumber                String                         @db.VarChar(100)
  businessAddress          String                         @db.VarChar(500)
  businessContactNumber    String                         @db.VarChar(100)
  customerStatus           String                         @db.VarChar(50)
  deletedAt                DateTime?
  additionalCustomerInfo   AdditionalCustomerInfo[]

  @@index([customerName])
  @@index([phoneNumber])
  @@index([customerStatus])
}

model AdditionalCustomerInfo {
  id         Int       @id @default(autoincrement())
  customerId Int
  type       String    @db.VarChar(50) // 'address', 'phone', 'shopee_username'
  value      String    @db.VarChar(500)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([type])
  @@map("additional_customer_info")
}

model Price {
  id              Int       @id @default(autoincrement())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @default(now()) @updatedAt
  productCode     String    @db.VarChar(100)
  lowerLimit      Int
  upperLimit      Int
  currentPrice    Int
  priceAdjustment Int       @default(0)
  description     String?   @db.VarChar(500)
  category        String?   @db.VarChar(100)
  isActive        Boolean   @default(true)
  deletedAt       DateTime?

  @@index([productCode])
  @@index([productCode, lowerLimit, upperLimit])
  @@index([isActive])
  @@map("prices")
}

model Product {
  id                     Int       @id @default(autoincrement())
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  shipmentCode           String?   @db.VarChar(100)
  cvNumber               String?   @db.VarChar(100)
  noOfSacks              Float     @default(0)
  totalCBM               Float     @default(0)
  weight                 Float     @default(0)
  shipmentStatus         String?   @db.VarChar(100)
  postingDate            String?   @db.VarChar(50)
  orderDate              String?   @db.VarChar(50)
  payment                String?   @db.VarChar(100)
  product                String?   @db.VarChar(500)
  productCode            String?   @db.VarChar(100)
  ageRange               String?   @db.VarChar(100)
  unit                   String?   @db.VarChar(50)
  unitPrice              Float     @default(0)
  quantity               Float     @default(0)
  alibabaShippingCost    Float     @default(0)
  exchangeRates          Float     @default(0)
  php                    Float     @default(0)
  subTotalPHP            Float     @default(0)
  transactionFee         Float     @default(0)
  grandTotal             Float     @default(0)
  forwardersFee          Float     @default(0)
  lalamove               Float     @default(0)
  packagingCost          Float     @default(0)
  suggestedPrice         Float     @default(0)
  actualPrice            Float     @default(0)
  basePrice              Float     @default(0)
  cogs                   Float     @default(0)
  projectedSales         Float     @default(0)
  projectedProfit        Float     @default(0)
  projectedProfitPercent Float     @default(0)
  totalMarkup            Float     @default(0)
  deletedAt              DateTime?

  @@index([productCode])
  @@index([shipmentCode])
  @@index([shipmentStatus])
  @@index([payment])
  @@index([ageRange])
  @@map("products")
}

model Shipment {
  id             Int       @id @default(autoincrement())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  shipmentCode   String    @db.VarChar(100)
  cvNumber       String?   @db.VarChar(100)
  noOfSacks      Int       @default(0)
  totalCBM       Float     @default(0)
  weight         Float     @default(0)
  fee            Float     @default(0)
  shipmentStatus String    @db.VarChar(100)
  dateCreated    String?   @db.VarChar(50)
  dateDelivered  String?   @db.VarChar(50)
  duration       String?   @db.VarChar(20)
  notes          String?
  deletedAt      DateTime?

  @@index([shipmentCode])
  @@index([shipmentStatus])
  @@map("shipments")
}

model Transaction {
  id           Int       @id @default(autoincrement())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  orderDate    String?   @db.VarChar(50)
  customers    String?   @db.VarChar(255)
  productCode  String?   @db.VarChar(100)
  quantity     Float?
  unitPrice    Float?
  discount     Float?
  adjustment   Float?
  lineTotal    Float?
  orderStatus  String?   @db.VarChar(100)
  notes        String?
  invoiceDate  String?   @db.VarChar(50)
  packedDate   String?   @db.VarChar(50)
  shipmentCode String?   @db.VarChar(100)
  deletedAt    DateTime?

  @@index([orderDate])
  @@index([customers])
  @@index([productCode])
  @@index([orderStatus])
  @@index([shipmentCode])
  @@index([customers, deletedAt])
  @@index([orderStatus, deletedAt])
  @@index([productCode, deletedAt])
  @@index([orderDate, deletedAt])
  @@map("transactions")
}

model SortingDistribution {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  productCode      String    @db.VarChar(100)
  selectedQuantity Int?
  rowNumber        Int
  quantity         Float     @default(0)
  percentage       Float     @default(0)
  groupNumber      String    @default("") @db.VarChar(50)
  distribution     Float     @default(0)
  checked          Boolean   @default(false)
  deletedAt        DateTime?

  @@unique([productCode, rowNumber])
  @@index([productCode])
  @@index([groupNumber])
  @@map("sorting_distributions")
}

model InstalledModule {
  id          String   @id @default(cuid())
  moduleId    String   @unique
  name        String   @db.VarChar(255)
  version     String   @db.VarChar(50)
  enabled     Boolean  @default(true)
  source      String   @db.VarChar(50)
  installPath String?  @db.VarChar(500)
  config      Json
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  installedBy String?  @db.VarChar(100)

  @@index([moduleId])
  @@index([enabled])
  @@index([source])
  @@map("installed_modules")
}

model ModuleMarketplace {
  id          String    @id @default(cuid())
  moduleId    String    @unique
  name        String    @db.VarChar(255)
  description String?
  version     String    @db.VarChar(50)
  author      String    @db.VarChar(255)
  authorEmail String?   @db.VarChar(255)
  downloadUrl String    @db.VarChar(1000)
  repository  String?   @db.VarChar(500)
  license     String?   @db.VarChar(100)
  size        Int?
  downloads   Int       @default(0)
  rating      Float?
  screenshots String[]
  keywords    String[]
  config      Json
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([moduleId])
  @@index([published])
  @@index([author])
  @@index([downloads])
  @@map("module_marketplace")
}

model AuditLog {
  id        String   @id @default(cuid())
  model     String   @db.VarChar(100)
  action    String   @db.VarChar(50)
  targetId  String?  @db.VarChar(100)
  before    Json?
  after     Json?
  timestamp DateTime @default(now())

  @@index([model])
  @@index([timestamp])
  @@map("audit_logs")
}

model Expense {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  date         String   @db.VarChar(50)
  amount       Float
  description  String   @db.VarChar(500)
  category     String   @db.VarChar(100)
  notes        String?
  receipt      String?  @db.VarChar(500)
  status       String   @db.VarChar(20)
  employeeName String?  @db.VarChar(255)

  @@index([date])
  @@index([category])
  @@index([status])
  @@index([employeeName])
  @@index([status, date])
  @@index([employeeName, status])
  @@index([category, status])
  @@map("expenses")
}

model Employee {
  id                            Int       @id @default(autoincrement())
  createdAt                     DateTime  @default(now())
  updatedAt                     DateTime  @updatedAt
  deletedAt                     DateTime?
  employeeId                    String    @unique @db.VarChar(50)
  firstName                     String    @db.VarChar(100)
  lastName                      String    @db.VarChar(100)
  middleName                    String?   @db.VarChar(100)
  name                          String    @db.VarChar(255)
  email                         String?   @db.VarChar(255)
  phone                         String?   @db.VarChar(50)
  contact                       String    @db.VarChar(50)
  address                       String?
  emergencyContactPerson        String?   @db.VarChar(255)
  emergencyContactNumber        String?   @db.VarChar(50)
  emergencyContact              String?   @db.VarChar(50)
  department                    String    @db.VarChar(100)
  position                      String    @db.VarChar(100)
  jobTitle                      String    @db.VarChar(100)
  status                        String    @db.VarChar(20)
  employmentStatus              String?   @db.VarChar(50)
  employeeType                  String?   @db.VarChar(50)
  office                        String?   @db.VarChar(255)
  hiringSource                  String?   @db.VarChar(100)
  hireDate                      String    @db.VarChar(50)
  basicSalary                   Float
  currentSalary                 Float?
  allowance                     Float?
  paymentSchedule               String?   @db.VarChar(50)
  bankAccount                   String?   @db.VarChar(255)
  gcashAccount                  String?   @db.VarChar(50)
  sssNumber                     String?   @db.VarChar(50)
  philHealthNumber              String?   @db.VarChar(50)
  hdmfNumber                    String?   @db.VarChar(50)
  tinNumber                     String?   @db.VarChar(50)
  gender                        String?   @db.VarChar(20)
  dateOfBirth                   String?   @db.VarChar(50)
  maritalStatus                 String?   @db.VarChar(20)
  numberOfKids                  Int?
  education                     String?   @db.VarChar(255)
  drivingLicense                String?   @db.VarChar(100)
  profilePhoto                  String?
  pagibigMonthlyContribution    Float?
  philHealthMonthlyContribution Float?
  sssMonthlyContribution        Float?
  taxMonthlyContribution        Float?

  @@index([employeeId])
  @@index([department])
  @@index([status])
  @@index([firstName, lastName])
  @@index([deletedAt])
  @@index([deletedAt, employeeId])
  @@index([status, deletedAt])
  @@index([department, deletedAt])
  @@map("employees")
}

model LeaveRequest {
  id            Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  employeeId    String?  @db.VarChar(50)
  employeeName  String   @db.VarChar(255)
  leaveType     String   @db.VarChar(50)
  startDate     String   @db.VarChar(50)
  endDate       String   @db.VarChar(50)
  numberOfDays  Int
  reason        String
  status        String   @db.VarChar(20)
  appliedDate   String   @db.VarChar(50)
  approvedBy    String?  @db.VarChar(255)
  notes         String?
  paymentStatus String   @default("unpaid") @db.VarChar(20)

  @@index([employeeId])
  @@index([employeeName])
  @@index([leaveType])
  @@index([status])
  @@index([paymentStatus])
  @@index([startDate])
  @@index([appliedDate])
  @@index([status, paymentStatus])
  @@index([employeeId, status])
  @@index([status, startDate])
  @@map("leave_requests")
}

model CashAdvanceRecord {
  id                String                 @id @default(cuid())
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  employeeId        String                 @db.VarChar(50)
  employeeName      String                 @db.VarChar(255)
  amount            Decimal                @db.Decimal(12, 2)
  termsMonths       Int?
  monthlyPayment    Decimal?               @db.Decimal(12, 2)
  settledAmount     Decimal?               @db.Decimal(12, 2)
  remainingBalance  Decimal?               @db.Decimal(12, 2)
  purpose           String?                @db.VarChar(255)
  notes             String?
  requestDate       DateTime?
  status            String                 @default("pending") @db.VarChar(20)
  approvedBy        String?                @db.VarChar(255)
  approvedDate      DateTime?
  rejectedBy        String?                @db.VarChar(255)
  rejectedDate      DateTime?
  rejectionReason   String?
  deductionCycle    CashAdvanceCycle?
  lastDeductedDate  DateTime?
  nextDeductionDate DateTime?
  deductions        CashAdvanceDeduction[]

  @@index([employeeId])
  @@index([status])
  @@index([requestDate])
  @@index([employeeId, status])
  @@index([status, requestDate])
  @@map("cash_advances")
}

model CashAdvanceDeduction {
  id            String            @id @default(cuid())
  cashAdvanceId String
  employeeId    String            @db.VarChar(50)
  payrollId     String?
  payPeriod     String?           @db.VarChar(100)
  deductionDate DateTime
  amount        Decimal           @db.Decimal(12, 2)
  createdAt     DateTime          @default(now())
  cashAdvance   CashAdvanceRecord @relation(fields: [cashAdvanceId], references: [id], onDelete: Cascade)

  @@index([cashAdvanceId])
  @@index([employeeId])
  @@map("cash_advance_deductions")
}

model Schedule {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  employeeId   String    @db.VarChar(50)
  employeeName String    @db.VarChar(255)
  date         String    @db.VarChar(50)
  shiftType    String    @db.VarChar(20)
  startTime    String    @db.VarChar(10)
  endTime      String    @db.VarChar(10)
  position     String    @db.VarChar(100)
  department   String    @db.VarChar(100)
  status       String    @default("scheduled") @db.VarChar(20)
  notes        String?
  source       String    @default("manual") @db.VarChar(20)
  templateId   String?   @db.VarChar(50)
  recurrenceId String?   @db.VarChar(50)
  isOverride   Boolean   @default(false)

  @@index([employeeId])
  @@index([employeeName])
  @@index([date])
  @@index([shiftType])
  @@index([status])
  @@index([department])
  @@index([deletedAt])
  @@index([employeeId, date, deletedAt])
  @@index([date, status, deletedAt])
  @@index([department, date, deletedAt])
  @@map("schedules")
}

model Attendance {
  id           String    @id @default(cuid())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  employeeId   String    @db.VarChar(50)
  employeeName String    @db.VarChar(255)
  department   String    @db.VarChar(100)
  position     String    @db.VarChar(100)
  date         String    @db.VarChar(50)
  timeIn       String    @db.VarChar(10)
  timeOut      String    @db.VarChar(10)
  break1Start  String?   @db.VarChar(10)
  break1End    String?   @db.VarChar(10)
  lunchStart   String?   @db.VarChar(10)
  lunchEnd     String?   @db.VarChar(10)
  break2Start  String?   @db.VarChar(10)
  break2End    String?   @db.VarChar(10)
  totalHours   Float
  status       String    @db.VarChar(20)
  details      String?   @db.VarChar(500)
  notes        String?

  @@index([employeeId])
  @@index([employeeName])
  @@index([date])
  @@index([status])
  @@index([department])
  @@index([deletedAt])
  @@index([status, date, deletedAt])
  @@index([employeeId, date, deletedAt])
  @@index([deletedAt, employeeId])
  @@map("attendance")
}

model EmployeeAutomationSetting {
  id                             String   @id @default(cuid())
  key                            String   @unique @default("default")
  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
  stayInAutoPresenceEnabled      Boolean  @default(true)
  stayInAutoPresenceTime         String   @default("02:00") @db.VarChar(5)
  stayInAutoPresenceTimezone     String   @default("Asia/Manila") @db.VarChar(50)
  stayInAutoPresenceGraceMinutes Int      @default(0)

  @@map("employee_automation_settings")
}

model Payroll {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  employeeId      String    @db.VarChar(50)
  employeeName    String    @db.VarChar(255)
  payPeriod       String    @db.VarChar(50)
  periodStart     String    @db.VarChar(50)
  periodEnd       String    @db.VarChar(50)
  basicSalary     Float     @default(0)
  allowance       Float     @default(0)
  overtime        Float     @default(0)
  bonuses         Float     @default(0)
  grossPay        Float     @default(0)
  sss             Float     @default(0)
  philHealth      Float     @default(0)
  pagIbig         Float     @default(0)
  tax             Float     @default(0)
  loans           Float     @default(0)
  lwop            Float     @default(0) @map("others")
  totalDeductions Float     @default(0)
  netPay          Float     @default(0)
  status          String    @default("pending") @db.VarChar(20)
  bankGcash       String    @db.VarChar(255)
  approvedBy      String?   @db.VarChar(255)
  approvedDate    String?   @db.VarChar(50)
  paidDate        String?   @db.VarChar(50)
  unpaidDays      Int       @default(0)
  dailyRate       Float     @default(0)
  deduction       Float     @default(0)
  notes           String?
  absentsLates    Float     @default(0)
  cashAdvance     Float     @default(0)
  thirteenthMonth Float     @default(0)

  @@index([employeeId])
  @@index([employeeName])
  @@index([payPeriod])
  @@index([periodStart])
  @@index([status])
  @@index([deletedAt])
  @@index([periodStart, periodEnd, deletedAt])
  @@index([employeeId, periodStart, deletedAt])
  @@index([status, deletedAt])
  @@map("payrolls")
}

model ThirteenthMonthPayRecord {
  id                 String   @id @default(cuid())
  recordId           String   @unique @db.VarChar(150)
  employeeId         String?  @db.VarChar(50)
  employeeName       String   @db.VarChar(255)
  year               Int
  status             String   @default("calculated") @db.VarChar(20)
  totalBasicSalary   Decimal  @default(0) @db.Decimal(14, 2)
  totalLwop          Decimal  @default(0) @db.Decimal(14, 2)
  totalAbsencesLates Decimal  @default(0) @db.Decimal(14, 2)
  netBasicSalary     Decimal  @default(0) @db.Decimal(14, 2)
  monthsWorked       Int      @default(1)
  thirteenthMonthPay Decimal  @default(0) @db.Decimal(14, 2)
  notes              String?
  calculatedDate     String?  @db.VarChar(50)
  approvedDate       String?  @db.VarChar(50)
  paidDate           String?  @db.VarChar(50)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([year])
  @@index([status])
  @@map("thirteenth_month_pay_records")
}

enum CashAdvanceCycle {
  FIRST_HALF
  SECOND_HALF
}

model CheckoutLink {
  id             String    @id @default(cuid())
  weight         String    @db.VarChar(50)
  width          String    @db.VarChar(50)
  length         String    @db.VarChar(50)
  height         String    @db.VarChar(50)
  checkoutLinks  String?   @db.VarChar(500)
  productPortals String?   @db.VarChar(500)
  productNames   String?   @db.VarChar(500)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  @@index([weight])
  @@index([deletedAt])
  @@index([weight, width, length, height])
  @@map("checkout_links")
}

model DispatchOrder {
  id                      String    @id @default(cuid())
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  orderId                 String    @db.VarChar(100)
  orderStatus             String?   @db.VarChar(100)
  returnRefundStatus      String?   @db.VarChar(100)
  trackingNumber          String?   @db.VarChar(100)
  shippingOption          String?   @db.VarChar(100)
  shipmentMethod          String?   @db.VarChar(100)
  estimatedShipOutDate    String?   @db.VarChar(50)
  shipTime                String?   @db.VarChar(50)
  orderCreationDate       String?   @db.VarChar(50)
  orderPaidTime           String?   @db.VarChar(50)
  parentSkuReferenceNo    String?   @db.VarChar(100)
  productName             String?   @db.VarChar(500)
  skuReferenceNo          String?   @db.VarChar(100)
  variationName           String?   @db.VarChar(500)
  originalPrice           Float?
  dealPrice               Float?
  quantity                Int?
  productSubtotal         Float?
  totalDiscount           Float?
  priceDiscountFromSeller Float?
  shopeeRebate            Float?
  skuTotalWeight          Float?
  numberOfProductsSeller  Int?
  originalShippingFee     Float?
  shippingFeeRebateSeller Float?
  reverseShippingFee      Float?
  serviceFee              Float?
  grandTotal              Float?
  estimatedShippingFee    Float?
  usernameBuyer           String?   @db.VarChar(100)
  receiverName            String?   @db.VarChar(255)
  phoneNumber             String?   @db.VarChar(50)
  deliveryAddress         String?
  town                    String?   @db.VarChar(255)
  district                String?   @db.VarChar(255)
  province                String?   @db.VarChar(255)
  region                  String?   @db.VarChar(255)
  country                 String?   @db.VarChar(100)
  zipCode                 String?   @db.VarChar(20)
  remarkFromBuyer         String?
  orderCompleteTime       String?   @db.VarChar(50)
  note                    String?
  linkedCustomerId        Int?
  importedAt              DateTime  @default(now())

  @@index([orderId])
  @@index([usernameBuyer])
  @@index([orderStatus])
  @@index([linkedCustomerId])
  @@index([importedAt])
  @@map("dispatch_orders")
}
