# Sample local environment file (do NOT use real secrets in git)
# Copy to .env.local for local dev, then fill with your values.

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# App base URLs
NEXT_PUBLIC_APP_URL="http://localhost:5001"
NEXTAUTH_URL="http://localhost:5001"

# Auth
NEXTAUTH_SECRET="change-me-to-a-32-char-or-longer-secret"

# Optional: port override
PORT=5001

# Optional: accounting cutover date (UTC midnight)
# Format: YYYY-MM-DD
# Example: ACCOUNTING_CUTOVER_DATE="2026-01-17"
ACCOUNTING_CUTOVER_DATE=""

# Optional: module-specific cutover overrides (UTC midnight)
# These override ACCOUNTING_CUTOVER_DATE for the given module only.
# Example:
#   ACCOUNTING_CUTOVER_DATE_CLOTHING="2026-02-01"
#   ACCOUNTING_CUTOVER_DATE_GM="2026-01-17"
ACCOUNTING_CUTOVER_DATE_CLOTHING=""
ACCOUNTING_CUTOVER_DATE_GM=""

# Google Drive (optional; fill if you use sync)
GOOGLE_DRIVE_FOLDER_ID=""
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""

# For production builds locally, you can temporarily copy your Render values into .env.local
# instead of these placeholders. Keep real secrets out of version control.
