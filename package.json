{
  "name": "business-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "dev:webpack": "next dev",
    "dev:clean": "bash scripts/clean-dev-cache.sh && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:imports": "node scripts/check-imports.js",
    "format": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:operations": "playwright test tests/e2e/operations-pages.spec.ts tests/e2e/transactions.spec.ts tests/e2e/invoice-generation.spec.ts tests/e2e/customers.spec.ts",
    "test:e2e:employees": "playwright test tests/e2e/employees-pages.spec.ts",
    "test:ui": "vitest --ui",
    "analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky install",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:test": "node scripts/test-db.js",
    "db:reset:test": "node scripts/reset-test-db.js --seed",
    "db:snapshot": "node scripts/db-snapshot.js",
    "generate:module": "node scripts/generate-module.js"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@glideapps/glide-data-grid": "^6.0.3",
    "@glideapps/glide-data-grid-cells": "^6.0.3",
    "@handsontable/react": "^16.1.1",
    "@mantine/core": "^7.0.0",
    "@mantine/dates": "^7.17.8",
    "@mantine/form": "^7.0.0",
    "@mantine/hooks": "^7.0.0",
    "@mantine/notifications": "^7.0.0",
    "@prisma/client": "^5.0.0",
    "@sentry/nextjs": "^10.22.0",
    "@tabler/icons-react": "^3.35.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "handlebars": "^4.7.8",
    "handsontable": "^16.1.1",
    "idb": "^8.0.3",
    "isomorphic-dompurify": "^2.30.1",
    "marked": "^16.4.1",
    "next": "^14.0.0",
    "openapi3-ts": "^4.5.0",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^24.23.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^3.2.1",
    "swagger-ui-react": "^5.30.0",
    "sweetalert2": "^11.26.3",
    "web-vitals": "^5.1.0",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@commitlint/cli": "^17.7.0",
    "@commitlint/config-conventional": "^17.7.0",
    "@next/bundle-analyzer": "^14.0.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.0",
    "eslint": "^8.48.0",
    "eslint-config-next": "^14.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^8.0.0",
    "jsdom": "^22.1.0",
    "lint-staged": "^16.2.6",
    "msw": "^2.0.0",
    "playwright": "^1.40.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "overrides": {
    "dompurify": "^3.2.4"
  }
}
