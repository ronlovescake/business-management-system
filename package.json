{
  "name": "business-management",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean:next": "bash scripts/clean-dev-cache.sh",
    "codegen:route-permissions": "node scripts/codegen-module-route-permissions.js",
    "dev": "next dev -H 0.0.0.0 -p 5001",
    "dev:turbo": "TURBOPACK=1 next dev --turbo -H 0.0.0.0 -p 5001",
    "dev:webpack": "next dev -H 0.0.0.0 -p 5001",
    "dev:playwright": "next dev -H 0.0.0.0 -p 3100",
    "dev:playwright:webpack": "next dev -H 0.0.0.0 -p 3100",
    "dev:docker": "bash scripts/docker/run-host-dev-against-docker-db.sh",
    "dev:docker:print-config": "bash scripts/docker/run-host-dev-against-docker-db.sh --print-config",
    "dev:clean": "npm run clean:next && npm run dev",
    "typecheck": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsc --pretty --noEmit -p tsconfig.typecheck.json",
    "ensure:playwright": "node scripts/ensure-playwright-browsers.js",
    "prebuild": "node scripts/check-required-env.js && node scripts/codegen-module-route-permissions.js && npm run lint && npm run typecheck && npm run clean:next",
    "build": "node scripts/build-webpack.js",
    "build:docker-env": "node scripts/run-build-with-env-file.js .env.docker run build",
    "postinstall": "npm run -s db:generate && node scripts/ensure-playwright-browsers.js",
    "prestart": "node scripts/ensure-playwright-browsers.js",
    "start": "next start -H 0.0.0.0 -p ${PORT:-5000}",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "lint:imports": "node scripts/check-imports.js",
    "guardrails:check": "node scripts/sync-liv1-status.js && node scripts/guard-no-legacy-browser-engine.js && node scripts/guardrails-check.js && node scripts/check-doc-command-drift.js && node scripts/codegen-module-route-permissions.js --check && node scripts/check-module-route-acl.js && node scripts/check-scripts-manifest.js && npm run -s backup:audit",
    "backup:audit": "tsx scripts/backup-schema-coverage-audit.ts",
    "guard:no-legacy-browser-engine": "node scripts/guard-no-legacy-browser-engine.js",
    "ci:quality": "npm run guardrails:check && npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:hardening",
    "format": "prettier --write .",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:hardening": "vitest run --config vitest.config.hardening.ts",
    "pretest:coverage": "node -e \"require('fs').mkdirSync('coverage/.tmp', { recursive: true })\"",
    "test:coverage": "vitest run --config vitest.config.coverage.ts --coverage",
    "test:coverage:enforce": "cross-env COVERAGE_ENFORCE=true vitest run --config vitest.config.coverage.ts --coverage",
    "test:full": "npm run lint && npm run typecheck && npm run test:unit && npm run test:integration && npm run test:hardening && npm run test:coverage:enforce && node scripts/run-if-db.js accounting:transactions:sanitycheck inventory:ledger:controls",
    "test:full:ci": "npm run test:full && npm run test:e2e",
    "pretest:e2e": "npm run -s ensure:playwright",
    "test:e2e": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test",
    "pretest:e2e:chromium": "npm run -s ensure:playwright",
    "test:e2e:chromium": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test --project=chromium",
    "pretest:e2e:operations": "npm run -s ensure:playwright",
    "test:e2e:operations": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test tests/e2e/operations-pages.spec.ts tests/e2e/transactions.spec.ts tests/e2e/invoice-generation.spec.ts tests/e2e/customers.spec.ts",
    "pretest:e2e:employees": "npm run -s ensure:playwright",
    "test:e2e:employees": "cross-env PLAYWRIGHT_BROWSERS_PATH=0 playwright test tests/e2e/employees-pages.spec.ts",
    "test:ui": "vitest --ui",
    "analyze": "cross-env ANALYZE=true next build",
    "prepare": "husky install",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:check-drift": "node scripts/check-schema-drift.js",
    "db:check-drift:production": "node scripts/check-schema-drift.js --docker production",
    "db:check-drift:dev": "node scripts/check-schema-drift.js --docker dev",
    "db:seed:auth": "node prisma/seeds/auth-users.js",
    "docker:bootstrap": "npm run db:deploy && npm run db:seed:auth",
    "docker:prepare-storage": "bash scripts/docker/prepare-host-storage.sh",
    "docker:backup:native-db": "bash scripts/docker/backup-native-db.sh",
    "docker:restore:pitr": "bash scripts/docker/restore-pitr-into-docker.sh",
    "docker:restore:pitr:scratch": "bash scripts/docker/restore-pitr-into-scratch.sh",
    "docker:restore:docker-db": "bash scripts/docker/restore-dump-into-docker.sh",
    "docker:restore:chain-drill": "bash scripts/docker/restore-chain-drill-into-docker.sh",
    "docker:restore:drill": "bash scripts/docker/restore-drill-into-docker.sh",
    "docker:restore:runner:up": "docker compose --env-file .env.docker up -d --build restore-runner",
    "docker:db:up": "docker compose --env-file .env.docker up -d db",
    "docker:db:wait": "docker compose --env-file .env.docker exec -T db sh -lc 'until pg_isready -U \"$POSTGRES_USER\" -d \"$POSTGRES_DB\" >/dev/null 2>&1; do echo \"Waiting for PostgreSQL...\"; sleep 1; done'",
    "docker:db:deploy": "npm run docker:db:wait && docker compose --env-file .env.docker run --rm app npm run db:deploy",
    "docker:build": "docker compose --env-file .env.docker build app",
    "docker:up": "docker compose --env-file .env.docker up -d app backup-scheduler",
    "docker:prod": "npm run docker:db:up && npm run docker:build && npm run docker:db:deploy && npm run db:check-drift:production && npm run docker:up",
    "docker:start:test": "docker compose -f docker-compose.test.yml up -d",
    "docker:clean:test": "docker compose -f docker-compose.test.yml down",
    "docker:backup:scheduler": "node scripts/run-backup-scheduler.js",
    "restore:plan": "tsx scripts/plan-restore.ts",
    "restore:replay": "tsx scripts/replay-restore-chain.ts",
    "restore:verify": "tsx scripts/verify-restore.ts",
    "db:studio": "prisma studio",
    "db:reset": "node scripts/prisma-safe-reset.js",
    "db:seed": "prisma db seed",
    "db:test": "node scripts/test-db.js",
    "db:reset:test": "node scripts/reset-test-db.js --seed",
    "db:snapshot": "node scripts/db-snapshot.js",
    "db:cleanup-placeholders": "node scripts/remove-placeholder-transactions.js",
    "generate:module": "node scripts/generate-module.js",
    "inventory:ledger:healthcheck": "tsx scripts/inventory-ledger-healthcheck.ts --failOnNegativeSellable",
    "refactor:changelog": "node scripts/build-refactor-changelog-stream.js",
    "inventory:ledger:drift": "tsx scripts/report-inventory-ledger-drift.ts --onlyWithMovements --minAbsDelta 0.000001 --failOnDrift",
    "inventory:ledger:controls": "npm run -s inventory:ledger:healthcheck && npm run -s inventory:ledger:drift",
    "inventory:ledger:rollback-sales-backfill": "tsx scripts/rollback-sale-backfill-movements.ts",
    "inventory:movements:resync-paid-prepared": "tsx scripts/resync-paid-prepared-inventory-movements.ts",
    "accounting:transactions:sanitycheck": "tsx scripts/accounting-sanity-check.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.1.0",
    "@glideapps/glide-data-grid": "^6.0.3",
    "@glideapps/glide-data-grid-cells": "^6.0.3",
    "@handsontable/react": "^16.1.1",
    "@mantine/core": "^7.0.0",
    "@mantine/dates": "^7.17.8",
    "@mantine/form": "^7.0.0",
    "@mantine/hooks": "^7.0.0",
    "@mantine/modals": "^7.17.8",
    "@mantine/notifications": "^7.0.0",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.22.0",
    "@tabler/icons-react": "^3.35.0",
    "@tanstack/react-query": "^5.0.0",
    "@tanstack/react-query-devtools": "^5.0.0",
    "@types/jszip": "^3.4.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "googleapis": "^165.0.0",
    "handlebars": "^4.7.8",
    "handsontable": "^16.1.1",
    "idb": "^8.0.3",
    "isomorphic-dompurify": "^2.30.1",
    "jszip": "^3.10.1",
    "marked": "^4.3.0",
    "next": "^14.2.33",
    "next-auth": "^4.24.13",
    "nodemailer": "^7.0.10",
    "openapi3-ts": "^4.5.0",
    "papaparse": "^5.5.3",
    "pdf-lib": "^1.17.1",
    "playwright": "^1.40.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-is": "^19.2.0",
    "react-responsive-carousel": "^3.2.23",
    "recharts": "^3.2.1",
    "swagger-ui-react": "^5.30.0",
    "sweetalert2": "^11.26.3",
    "stream-json": "^1.9.1",
    "web-vitals": "^5.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.0",
    "@commitlint/cli": "^17.7.0",
    "@commitlint/config-conventional": "^17.7.0",
    "@next/bundle-analyzer": "^14.2.33",
    "@playwright/test": "^1.40.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.3",
    "@types/papaparse": "^5.5.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/stream-json": "^1.7.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.0",
    "baseline-browser-mapping": "^2.9.18",
    "cross-env": "^7.0.0",
    "eslint": "^8.48.0",
    "eslint-config-next": "^14.2.33",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^8.0.0",
    "jsdom": "^22.1.0",
    "lint-staged": "^16.2.6",
    "msw": "^2.0.0",
    "postcss": "^8.4.0",
    "prettier": "^3.0.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.3.0",
    "tsx": "4.19.2",
    "typescript": "5.3.3",
    "vitest": "^1.0.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "overrides": {
    "dompurify": "^3.2.4"
  }
}
