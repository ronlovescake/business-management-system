<!-- views/invoice.hbs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Invoice</title>
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,700;1,400&family=Comfortaa:wght@700&display=swap" rel="stylesheet">
  <style>
    /* Reset & Base */
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    body {
      font-family: 'DM Sans', sans-serif;
      background: #f0f0f0;
      padding: 0px 0;
    }

    /* Container */
    .invoice-container {
      width: 817px;
      margin: 0 auto;
      background: #fff;
      position: relative;
      min-height: 1000px;  /* Slightly reduced height to accommodate row padding */
      display: flex;
      flex-direction: column;
    }

    /* Top & Bottom Bars */
    .bar {
      width: 100%;
      height: 18px;
      background-color: #cc0000;
    }

    /* Header Section */
    .body-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      padding: 20px;      /* 20px padding to the sides */
      margin-top: 20px;    /* Reduce space from top bar */
      margin-bottom: 15px; /* Reduce space before "Prepared for" */
    }

    /* Wrap title + date for independent spacing */
    .header-text {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
    }

    /* Invoice Title */
    .invoice-title {
      font-size: 20pt;
      color: #cc0000;
      margin-top: 50px;      /* Reduce top margin */
      margin-bottom: 35px;   /* Reduce bottom margin */
    }

    /* Invoice Date */
    .invoice-date {
      font-size: 12pt;
      color: #000;
      margin-top: 0;
    }

    /* Logo sizing */
    .logo {
      max-width: 190px;
    }

    /* "Prepared for" Table */
    .info-table {
      width: calc(100% - 40px);
      margin: 0 20px 20px;
      border-collapse: collapse;
    }
    .info-table td {
      vertical-align: top;
      padding: 3px;
    }
    .info-table .label {
      font-family: 'Comfortaa', cursive;
      font-size: 12pt;
      font-weight: bold;
      margin-bottom: 8px;
    }
    .info-table .value {
      font-family: 'Comfortaa', cursive;
      font-size: 15pt;
      font-weight: bold;
      color: #660000;
      margin-bottom: 8px;
    }
    .info-table .contact {
      font-family: 'Comfortaa', cursive;
      font-size: 10pt;
      font-weight: bold;
      margin-bottom: 8px;
    }
    .info-table td:nth-child(2) {
      text-align: right;
    }

    /* Content area that expands to push footer down */
    .content-area {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    /* Items Table with white borders */
    .items-table {
      width: calc(100% - 40px);
      border-collapse: collapse;
      margin: -20px 20px 20px;  /* Add bottom margin for spacing */
    }
    .items-table th,
    .items-table td {
      border: 1px solid #ffffff;
      padding: 4px;              /* Reduce padding slightly */
      height: 22pt;              /* Reduce row height slightly */
      font-size: 10pt;
    }
    .items-table th {
      background-color: #cc0000;
      color: #ffffff;
      font-weight: bold;
      text-align: center;
    }
    .items-table tr:nth-child(even) td {
      background-color: #f3f3f3;
    }
    
    

    /* right-align numeric cells */
    .items-table td.right {
      text-align: right;
    }

    /* Footer area that sticks to bottom */
    .footer-area {
      margin-top: auto;  /* Push to bottom */
    }

    /* Summary & Notes */
    .summary {
      width: calc(100% - 40px);
      border: 1px solid #cccccc;
      border-collapse: collapse;
      margin: 10px 20px 10px;    /* Standard margins for footer */
    }
    .summary td {
      vertical-align: top;
      padding: 8px;              /* Slightly increase padding for better readability */
    }
    .summary .due {
      font-size: 15pt;
      font-weight: bold;
      color: #cc0000;
    }
    .summary em {
      display: block;
      font-style: italic;
      font-size: 9pt;
      color: #555;
      margin-bottom: 5px;
    }
    .summary .note-title {
      font-size: 12pt;
      font-weight: bold;
      color: #cc0000;
      margin: 10px 0 5px;
    }
    .summary .note {
      font-size: 11pt;
      margin-bottom: 3px;
    }

    /* Center-align the left side of the summary (due date & notes) */
    .summary td:first-child {
      text-align: center;
    }

    /* Totals Table */
    .totals-table {
      width: 100%;
      border-collapse: collapse;
    }
    .totals-table td {
      padding: 5px;
      font-size: 10pt;
    }
    .totals-table td.label {
      text-align: left;
    }
    .totals-table td.value {
      text-align: right;
    }
    .totals-table .amount-due .label,
    .totals-table .amount-due .value {
      font-size: 12pt;
      font-weight: bold;
      color: #cc0000;
    }

    /* Right-align Sub Total, Adjustment & Amount Due */
    .totals-table td.label,
    .totals-table td.value {
      text-align: right;
    }


    /* Flexible spacer that expands to fill remaining space and push footer to bottom */
    .flexible-spacer {
      flex: 1;
      min-height: 10px;  /* Minimum spacing between table and footer */
    }

    /* Fixed bottom spacer */
    .spacer {
      height: 10px;
    }
  </style>
</head>
<body>
  <div class="invoice-container">

    <!-- Top red bar -->
    <div class="bar"></div>

    <!-- Content area that expands to push footer down -->
    <div class="content-area">
      <!-- Header: Invoice title + date + logo -->
      <div class="body-header">
        <div class="header-text">
          <h1 class="invoice-title">INVOICE</h1>
          <div class="invoice-date">Invoice Date: {{date}}</div>
        </div>
        <img src="data:image/png;base64,{{logoData}}" alt="Logo" class="logo" />
      </div>

      <!-- "Prepared for" / "Order from" table -->
      <table class="info-table">
        <tr>
          <td width="60%">
            <div class="label">Prepared for</div>
            <div class="value">{{customerName}}</div>
            <div class="contact">{{phone}}</div>
            <div class="contact">{{address}}</div>
          </td>
          <td width="40%">
            <div class="label">Order from</div>
            <div class="value">Czarlie &amp; Ron</div>
          </td>
        </tr>
      </table>

      <!-- Items listing -->
      <table class="items-table">
        <thead>
          <tr>
            <th>ITEM DESCRIPTION</th>
            <th>QUANTITY</th>
            <th>UNIT PRICE</th>
            <th>ADJUSTMENT</th>
            <th>LINE TOTAL</th>
          </tr>
        </thead>
        <tbody id="invoice-items">
          {{#each items}}
          <tr>
            <td>{{description}}</td>
            <td style="text-align:center">{{quantity}}</td>
<td class="right">{{currency unitPrice}}</td>
<td class="right">{{currency adjustment}}</td>
<td class="right">{{currency lineTotal}}</td>

          </tr>
          {{/each}}
        </tbody>
      </table>

      <!-- Auto-pad empty rows for consistent table height -->
      <script>
        (function(){
          const tbody = document.getElementById('invoice-items');
          const currentRows = tbody.rows.length;
          
          // Calculate how many rows should fit in the available space
          // This creates a consistent table appearance
          let targetRows;
          if (currentRows <= 3) {
            targetRows = 15;      // Small orders get more empty rows for consistency
          } else if (currentRows <= 6) {
            targetRows = 12;      // Medium orders (like consolidated) get moderate padding
          } else if (currentRows <= 9) {
            targetRows = currentRows + 3;  // Large orders get minimal padding
          } else {
            targetRows = currentRows + 1;  // Very large orders get just one extra row
          }
          
          while (tbody.rows.length < targetRows) {
            const tr = document.createElement('tr');
            for (let i = 0; i < 5; i++) {
              const td = document.createElement('td');
              td.innerHTML = '&nbsp;';
              tr.appendChild(td);
            }
            tbody.appendChild(tr);
          }
        })();
      </script>

      <!-- Flexible spacer that expands to push footer to bottom -->
      <div class="flexible-spacer"></div>
    </div>

    <!-- Footer area that stays at bottom -->
    <div class="footer-area">
      <!-- Summary & Notes -->
      <table class="summary">
      <tr>
        <td width="60%">
          <div class="due">DUE DATE: {{dueDate}}</div>
          <em>Please complete this transaction on or before the due date</em>
          <div class="note-title">PLEASE TAKE NOTE !!!</div>
          <div class="note">For Shopee checkout: Deduct ₱50.00 from the “Amount Due”</div>
          <div class="note">For Lalamove pickup: Please send the full “Amount Due”</div>
        </td>
        <td width="40%">
          <table class="totals-table">
            <tr>
              <td class="label">Sub Total:</td>
              <td class="value">{{currency subTotal}}</td>
            </tr>
            <tr>
              <td class="label">Adjustment:</td>
              <td class="value">{{currency creditAmount}}</td>
            </tr>
            <tr><td colspan="2"><hr></td></tr>
            <tr class="amount-due">
              <td class="label">AMOUNT DUE:</td>
              <td class="value">{{currency orderTotal}}</td>
            </tr>
          </table>
        </td>
      </tr>
    </table>

    <!-- Bottom spacer -->
    <div class="spacer"></div>

      <!-- Bottom red bar -->
      <div class="bar"></div>
    </div>
  </div>
</body>
</html>

