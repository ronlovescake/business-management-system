# ============================================================================
# BUSINESS MANAGEMENT SYSTEM - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains sensitive data!
#
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]
# ============================================================================

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================

# Node environment - controls application behavior
# Values: development, test, production
# [REQUIRED]
NODE_ENV="development"


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL database connection URL
# Format: postgresql://username:password@host:port/database
# [REQUIRED] - Except in test environment (uses mock database)
#
# Development example:
DATABASE_URL="postgresql://postgres:password@localhost:5432/business_management"
#
# Production example (with optimized connection pooling):
# DATABASE_URL="postgresql://user:password@your-db-host.com:5432/business_management?sslmode=require&connection_limit=10&pool_timeout=20&connect_timeout=10"
#
# Connection Pool Parameters:
# - sslmode=require: Enforce SSL encryption (REQUIRED for production)
# - connection_limit=10: Max concurrent connections per process
#   * Development: 5-10 connections
#   * Production: 10-20 connections (adjust based on traffic)
#   * Formula: (num_cpu_cores * 2) + effective_spindle_count
#   * Too high: Database connection exhaustion
#   * Too low: Request queueing and timeouts
# - pool_timeout=20: Wait time (seconds) for available connection
#   * Recommended: 10-30 seconds
#   * Prevents indefinite waiting for connections
# - connect_timeout=10: TCP connection timeout (seconds)
#   * Recommended: 5-10 seconds
#   * Fast failure for unreachable databases
#
# Production Best Practices:
# 1. Always use SSL (sslmode=require)
# 2. Set connection_limit based on your workload and server capacity
# 3. Monitor slow queries (logged automatically if >100ms)
# 4. Use connection pooling at infrastructure level (PgBouncer) for high-traffic apps
# 5. Set pool_timeout to prevent connection exhaustion
# 6. Use environment-specific connection limits (lower for dev, higher for prod)
#
# Monitoring:
# - Slow queries (>100ms) are automatically logged
# - Use getDatabaseStats() to monitor query performance
# - Use testDatabaseConnection() for health checks


# ============================================================================
# APPLICATION URLS
# ============================================================================

# Base URL for the application (used for absolute URLs in emails, API calls, etc.)
# [OPTIONAL] - Defaults to window.location.origin on client-side
# [REQUIRED] - In production for server-side operations
#
# Development:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
#
# Production:
# NEXT_PUBLIC_APP_URL="https://yourdomain.com"


# ============================================================================
# AUTHENTICATION (Future Implementation)
# ============================================================================
# Note: Authentication is currently DEFERRED and will be implemented before production deployment
# These variables are optional now but will be REQUIRED for production

# NextAuth URL - The base URL of your application for authentication
# [OPTIONAL] - Required when authentication is implemented
NEXTAUTH_URL="http://localhost:3000"

# NextAuth Secret - Random string used to hash tokens and sign cookies
# Generate with: openssl rand -base64 32
# [OPTIONAL] - Required when authentication is implemented
# MUST be at least 32 characters long
NEXTAUTH_SECRET="your-secret-key-here-minimum-32-characters-required"


# ============================================================================
# ERROR TRACKING & MONITORING
# ============================================================================

# Sentry DSN for error tracking (client-side and server-side)
# Get this from your Sentry project settings
# [OPTIONAL] - Highly recommended for production
#
# Example:
# NEXT_PUBLIC_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry organization name (for source maps and releases)
# [OPTIONAL] - Required if using Sentry
SENTRY_ORG=""

# Sentry project name
# [OPTIONAL] - Required if using Sentry
SENTRY_PROJECT=""

# Sentry authentication token (for uploading source maps)
# Get this from: Settings > Developer Settings > Auth Tokens
# [OPTIONAL] - Required if using Sentry
SENTRY_AUTH_TOKEN=""


# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Enable detailed query logging to console
# Values: true, false
# [OPTIONAL] - Defaults to false
# 
# When enabled:
# - All Prisma queries logged to console
# - Slow queries (>100ms) highlighted
# - Query execution time shown
#
# WARNING: Enable only in development - creates verbose logs
LOG_ALL_QUERIES="false"

# Enable Next.js Turbopack (faster development builds)
# Values: 1 (enabled), 0 (disabled)
# [OPTIONAL] - Defaults to disabled
# 
# Usage: Set to "1" to use Turbopack instead of Webpack
# Note: Turbopack is currently in beta and may have compatibility issues
# TURBOPACK="0"

# Enable bundle analyzer
# Values: true, false
# [OPTIONAL] - Used to analyze bundle size
#
# Usage: Set to "true" and run "npm run build" to generate bundle analysis
# Output: Opens interactive treemap of bundle contents in browser
# ANALYZE="false"

# CI environment flag
# Values: true, false
# [OPTIONAL] - Automatically set by CI/CD systems (GitHub Actions, etc.)
#
# When set:
# - Test reporter uses machine-readable formats (JUnit XML)
# - Playwright uses fewer workers (1 worker in CI)
# - Storage state disabled in E2E tests
# CI="false"


# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================
# Use these to toggle features in different environments

# Enable debug panel in development
# [OPTIONAL] - Automatically enabled in development
# DEBUG_PANEL="true"

# Enable verbose logging
# [OPTIONAL] - Automatically enabled in development
# VERBOSE_LOGGING="true"


# ============================================================================
# EXTERNAL INTEGRATIONS (Add as needed)
# ============================================================================

# Google Drive Integration
# [OPTIONAL] - Required for syncing invoice files from Google Drive
#
# Setup Instructions:
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a new project or select existing one
# 3. Enable Google Drive API
# 4. Create a Service Account:
#    - Go to "IAM & Admin" > "Service Accounts"
#    - Click "Create Service Account"
#    - Grant "Editor" role (or customize permissions)
#    - Click "Done"
# 5. Generate JSON key:
#    - Click on the service account email
#    - Go to "Keys" tab
#    - Click "Add Key" > "Create new key"
#    - Select "JSON" and download
# 6. Share your Google Drive folder with the service account email
#    - Open your Google Drive folder
#    - Click "Share"
#    - Paste the service account email (looks like: name@project-id.iam.gserviceaccount.com)
#    - Give "Viewer" or "Editor" permissions
# 7. Copy values from the JSON file to these environment variables:
#
# The folder ID from your Google Drive URL
# Example: https://drive.google.com/drive/folders/1reLxZAgqSy3xfMaG4lqFSVWAcYHbCjz8
# The folder ID is: 1reLxZAgqSy3xfMaG4lqFSVWAcYHbCjz8
GOOGLE_DRIVE_FOLDER_ID="1reLxZAgqSy3xfMaG4lqFSVWAcYHbCjz8"

# Service account email from JSON key file (client_email field)
GOOGLE_CLIENT_EMAIL="your-service-account@your-project.iam.gserviceaccount.com"

# Private key from JSON key file (private_key field)
# IMPORTANT: Keep the quotes and \n characters as-is
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# API keys for external services
# [OPTIONAL] - Add as you integrate with external services
#
# Examples:
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# SENDGRID_API_KEY="SG..."
# AWS_ACCESS_KEY_ID="AKIA..."
# AWS_SECRET_ACCESS_KEY="..."
# CLOUDINARY_URL="cloudinary://..."


# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in required values (marked with [REQUIRED])
#
# 3. Set up your PostgreSQL database:
#    - Install PostgreSQL if not already installed
#    - Create database: createdb business_management
#    - Update DATABASE_URL with your connection details
#
# 4. Run database migrations:
#    npx prisma migrate dev
#
# 5. (Optional) Seed database with sample data:
#    npx prisma db seed
#
# 6. (Optional) Set up Sentry for error tracking:
#    - Create account at sentry.io
#    - Create new project
#    - Copy DSN to NEXT_PUBLIC_SENTRY_DSN
#    - Add organization, project, and auth token for source maps
#
# 7. Start development server:
#    npm run dev
#
# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
#
# Before deploying to production, ensure:
# ✅ NODE_ENV is set to "production"
# ✅ DATABASE_URL points to production database with SSL
# ✅ NEXT_PUBLIC_APP_URL is set to your production domain
# ✅ NEXTAUTH_URL matches your production domain (when auth is implemented)
# ✅ NEXTAUTH_SECRET is a strong random string (when auth is implemented)
# ✅ Sentry is configured for error tracking
# ✅ LOG_ALL_QUERIES is set to "false" (to reduce log volume)
# ✅ All secrets are stored securely (use environment variable service)
# ✅ Connection pooling is properly configured in DATABASE_URL
#
# ============================================================================