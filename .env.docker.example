BMS_DATA_ROOT=/home/YOUR_USERNAME/business-management-system-data

APP_PORT=5000
POSTGRES_PORT=5432

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=business_management

DATABASE_URL=postgresql://postgres:change-me@db:5432/business_management?schema=public&connection_limit=10&pool_timeout=20&connect_timeout=10

NEXT_PUBLIC_APP_URL=http://localhost:5000
NEXTAUTH_URL=http://localhost:5000
NEXTAUTH_SECRET=change-me-to-a-random-secret-with-at-least-32-characters

LOG_ALL_QUERIES=false

# Optional integrations
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=
INTERNAL_JOB_TOKEN=
BACKUP_STRICT_TABLES=
BACKUP_AUTO_ENABLED=false
BACKUP_AUTO_TIME=22:00
BACKUP_AUTO_CADENCE=weekly
BACKUP_AUTO_DAY_OF_WEEK=sunday
BACKUP_DIFF_AUTO_ENABLED=false
BACKUP_DIFF_AUTO_TIME=12:00
BACKUP_DIFF_AUTO_FORMAT=json
BACKUP_AUTO_TIMEZONE=Asia/Manila
BACKUP_RETENTION_DAYS=30
PITR_ENABLED=false
PITR_ARCHIVE_TIMEOUT_SECONDS=300
PITR_BASE_AUTO_ENABLED=false
PITR_BASE_AUTO_TIME=01:00
RESTORE_RUNNER_POLL_MS=5000